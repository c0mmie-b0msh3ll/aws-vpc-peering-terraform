          <mxGeometry width="40" height="38" y="2" as="geometry" />
        </mxCell>
        <mxCell id="legend-6-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Data Layer&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;ECS reads/writes DynamoDB via Gateway VPC Endpoint. ElastiCache #1 caches API responses; ElastiCache #2 is the Socket.io Redis adapter pub/sub bus across tasks.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="legend-6">
          <mxGeometry x="52" width="288" height="120" as="geometry" />
        </mxCell>

