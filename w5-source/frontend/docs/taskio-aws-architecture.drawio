        <mxCell id="legend-3-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Authentication&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Cognito User Pool issues JWT (access + refresh) used as Bearer tokens on API calls.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="legend-3">
          <mxGeometry x="52" width="288" height="100" as="geometry" />
        </mxCell>

