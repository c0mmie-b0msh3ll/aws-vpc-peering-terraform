          <mxGeometry width="40" height="38" y="2" as="geometry" />
        </mxCell>
        <mxCell id="legend-8-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;CI/CD Blue/Green&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;GitHub push → CodePipeline V2 → CodeBuild builds and pushes Docker image to ECR → CodeDeploy performs canary 10% Blue/Green shift to ECS Fargate with auto-rollback on alarms.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="legend-8">
          <mxGeometry x="52" width="288" height="120" as="geometry" />
        </mxCell>

        <!-- Line styles legend -->
        <mxCell id="legend-line-title" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;fontStyle=1;fontFamily=Helvetica;labelBackgroundColor=none;" value="Line Styles" vertex="1" parent="1">
          <mxGeometry x="2520" y="1140" width="320" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-line-solid" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#232F3E;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2520" y="1180" as="sourcePoint" />
            <mxPoint x="2620" y="1180" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="legend-line-solid-text" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontFamily=Helvetica;labelBackgroundColor=none;" value="Data flow / request path" vertex="1" parent="1">
          <mxGeometry x="2630" y="1170" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-line-dashed" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#232F3E;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2520" y="1210" as="sourcePoint" />
            <mxPoint x="2620" y="1210" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="legend-line-dashed-text" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontFamily=Helvetica;labelBackgroundColor=none;" value="Control plane / management" vertex="1" parent="1">
          <mxGeometry x="2630" y="1200" width="240" height="20" as="geometry" />
        </mxCell>

        <!-- Trade-off note -->
        <mxCell id="legend-note-title" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;fontStyle=1;fontFamily=Helvetica;labelBackgroundColor=none;" value="Why public ALB (not API Gateway / VPC Origins)?" vertex="1" parent="1">
          <mxGeometry x="2520" y="1260" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend-note-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=12;fontFamily=Helvetica;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;API Gateway WebSocket API breaks Socket.io's HTTP long-polling → upgrade handshake. CloudFront VPC Origins (Nov 2024) do not support WebSocket as of Mar 2025. Public ALB is the only option that handles REST + WebSocket natively with no special config.&lt;/span&gt;" vertex="1" parent="1">
          <mxGeometry x="2520" y="1310" width="340" height="180" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
