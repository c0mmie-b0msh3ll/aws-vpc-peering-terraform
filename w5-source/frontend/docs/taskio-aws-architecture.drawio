        </mxCell>
        <mxCell id="legend-5-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="5" vertex="1" parent="legend-5">
          <mxGeometry width="40" height="38" y="2" as="geometry" />
        </mxCell>
        <mxCell id="legend-5-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Load Balancing (Multi-AZ)&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Public ALB spans both AZs. Sticky sessions handle Socket.io polling fallback. Targets are Fargate IPs in private subnets.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="legend-5">
          <mxGeometry x="52" width="288" height="120" as="geometry" />
        </mxCell>

        <!-- Step 6 entry -->
        <mxCell id="legend-6" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="1">
