        <mxCell id="legend-4-text" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;API Edge Filtering&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Regional WAF on ALB enforces OWASP rules and per-route rate limits on auth endpoints.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="legend-4">
          <mxGeometry x="52" width="288" height="100" as="geometry" />
        </mxCell>

        <!-- Step 5 entry -->
