        <mxCell id="notes-title" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontFamily=Helvetica;fontColor=#F57C00;fontStyle=1;" value="⚠ Deliberate omissions (Week 1 scope) — have answers ready if asked:" vertex="1" parent="notes-box">
          <mxGeometry x="15" y="10" width="1000" height="20" as="geometry" />
        </mxCell>
        <mxCell id="notes-body" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Helvetica;fontColor=#333333;" value="&lt;b&gt;No ALB / ASG&lt;/b&gt; — $16/mo, not Free Tier. Single EC2 accepted for Week 1. Upgrade path: ASG + ALB across 2 AZs.  &amp;nbsp; &lt;b&gt;No Cognito&lt;/b&gt; — Taskio already has custom JWT auth in JwtProvider.js.&lt;br&gt;&lt;b&gt;No CloudFront&lt;/b&gt; — Amplify Hosting includes a CDN for the SPA. &amp;nbsp; &lt;b&gt;No WAF / Secrets Manager / ElastiCache&lt;/b&gt; — cost vs Week 1 scope. &amp;nbsp; &lt;b&gt;DynamoDB vs MongoDB&lt;/b&gt; — requires one-time repo/ folder rewrite, accepted for $0/mo DB.&lt;br&gt;&lt;b&gt;Single AZ&lt;/b&gt; — acknowledged trade-off. If ap-southeast-1a fails, ~10 min manual recovery. Multi-AZ is the documented next step." vertex="1" parent="notes-box">
          <mxGeometry x="15" y="30" width="1990" height="55" as="geometry" />
        </mxCell>

      </root>
