        <mxCell id="legend-body" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Helvetica;fontColor=#333333;" value="&lt;b&gt;B.1 Compute&lt;/b&gt; (5đ)&lt;br&gt;EC2 t3.micro — Node monolith&lt;br&gt;&lt;br&gt;&lt;b&gt;B.2 Database&lt;/b&gt; (5đ)&lt;br&gt;DynamoDB — NoSQL, Always Free&lt;br&gt;&lt;br&gt;&lt;b&gt;B.3 Storage&lt;/b&gt; (5đ)&lt;br&gt;S3 — attachments, avatars&lt;br&gt;&lt;br&gt;&lt;b&gt;B.4 Network&lt;/b&gt; (5đ)&lt;br&gt;VPC + Public/Private Subnet&lt;br&gt;+ IGW + Security Group&lt;br&gt;(no ELB — rubric says optional)&lt;br&gt;&lt;br&gt;&lt;b&gt;B.5 Security&lt;/b&gt; (5đ)&lt;br&gt;IAM Role (no access keys)&lt;br&gt;+ Shared Responsibility&lt;br&gt;&lt;br&gt;&lt;b&gt;B.6 Region/AZ&lt;/b&gt; (3đ)&lt;br&gt;ap-southeast-1, AZ 1a&lt;br&gt;&lt;br&gt;&lt;b&gt;B.7 Cost&lt;/b&gt; (2đ)&lt;br&gt;~$0–1/mo Year 1&lt;br&gt;~$11/mo Year 2+" vertex="1" parent="legend-box">
          <mxGeometry x="12" y="48" width="180" height="470" as="geometry" />
        </mxCell>

