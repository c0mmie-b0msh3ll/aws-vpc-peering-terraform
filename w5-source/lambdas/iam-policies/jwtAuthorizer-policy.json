{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:us-east-1:072937283954:log-group:/aws/lambda/taskio-w5-jwtAuthorizer",
        "arn:aws:logs:us-east-1:072937283954:log-group:/aws/lambda/taskio-w5-jwtAuthorizer:*"
      ]
    },
    {
      "Sid": "ReadJwtSecretFromSsm",
      "Effect": "Allow",
      "Action": "ssm:GetParameter",
      "Resource": "arn:aws:ssm:us-east-1:072937283954:parameter/taskio/w5/jwt-access-secret"
    },
    {
      "Sid": "DecryptSsmSecureString",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "arn:aws:kms:us-east-1:072937283954:alias/aws/ssm"
    }
  ]
}
